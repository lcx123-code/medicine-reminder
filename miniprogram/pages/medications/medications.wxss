/* 药品管理页面样式 - 精致版 */
.container {
  padding: 24rpx;
  padding-bottom: 180rpx;
  min-height: 100vh;
  background: linear-gradient(180deg, #E8F4FD 0%, #F5F7FA 100%);
}

/* 骨架屏样式 */
.skeleton {
  padding: 24rpx;
}

.skeleton-card {
  background: #fff;
  border-radius: 28rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 6rpx 24rpx rgba(0, 0, 0, 0.06);
}

.skeleton-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
  padding-bottom: 24rpx;
  border-bottom: 2rpx solid #F7FAFC;
}

.skeleton-line {
  height: 28rpx;
  background: linear-gradient(135deg, #E2E8F0 0%, #CBD5E0 100%);
  border-radius: 8rpx;
  animation: skeleton-pulse 1.5s ease-in-out infinite;
}

.skeleton-name {
  width: 200rpx;
  height: 40rpx;
}

.skeleton-tag {
  width: 100rpx;
  height: 32rpx;
}

.skeleton-body {
  padding: 16rpx 0;
}

.skeleton-info {
  width: 60%;
  height: 24rpx;
  margin-bottom: 16rpx;
}

@keyframes skeleton-pulse {
  0%, 100% {
    opacity: 1;
  }
  50% {
    opacity: 0.5;
  }
}

/* 搜索栏样式 */
.search-bar {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 24rpx;
  padding: 20rpx 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
  border: 2rpx solid transparent;
  transition: all 0.3s ease;
}

.search-bar:focus-within {
  border-color: #667EEA;
  box-shadow: 0 0 0 4rpx rgba(102, 126, 234, 0.1);
}

.search-icon {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #EDF2F7 0%, #E2E8F0 100%);
  border-radius: 12rpx;
  margin-right: 20rpx;
  font-size: 24rpx;
  color: #718096;
  font-weight: 500;
}

.search-input {
  flex: 1;
  height: 56rpx;
  font-size: 30rpx;
  color: #2D3748;
}

.search-clear {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #EDF2F7 0%, #E2E8F0 100%);
  border-radius: 50%;
  font-size: 32rpx;
  color: #718096;
  font-weight: 500;
  transition: all 0.3s ease;
}

.search-clear:active {
  background: linear-gradient(135deg, #FED7D7 0%, #FEB2B2 100%);
  color: #C53030;
}

/* 筛选标签样式 */
.filter-tabs {
  display: flex;
  background: #fff;
  border-radius: 20rpx;
  padding: 8rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.03);
}

.filter-tab {
  flex: 1;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 14rpx;
  font-size: 28rpx;
  color: #64748B;
  font-weight: 500;
  transition: all 0.3s ease;
}

.filter-tab.active {
  background: linear-gradient(135deg, #667EEA 0%, #764BA2 100%);
  color: #fff;
  font-weight: 600;
  box-shadow: 0 4rpx 12rpx rgba(102, 126, 234, 0.3);
}

.filter-tab:active {
  transform: scale(0.98);
}

/* 左滑删除样式 */
.medication-card-wrapper {
  position: relative;
  overflow: hidden;
  border-radius: 28rpx;
  margin-bottom: 24rpx;
}

.swipe-bg {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  width: 150rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  transition: opacity 0.3s ease;
}

.swipe-bg.visible {
  opacity: 1;
}

.swipe-delete {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(245, 101, 101, 0.85);
  backdrop-filter: blur(10px);
  -webkit-backdrop-filter: blur(10px);
  color: #fff;
  font-size: 28rpx;
  font-weight: 600;
  border-radius: 0 28rpx 28rpx 0;
}

/* 药品列表 */
.medication-list {
  margin-bottom: 32rpx;
}

.medication-card {
  position: relative;
  background: #fff;
  border-radius: 28rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 6rpx 24rpx rgba(0, 0, 0, 0.06);
  border: 1rpx solid rgba(255, 255, 255, 0.8);
  transition: transform 0.3s ease;
  z-index: 1;
}

.medication-card:active {
  transform: scale(1);
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 24rpx;
  padding-bottom: 24rpx;
  border-bottom: 2rpx solid #F7FAFC;
}

.med-name-status {
  flex: 1;
}

.med-name {
  font-size: 36rpx;
  font-weight: 700;
  color: #2D3748;
  display: block;
  margin-bottom: 12rpx;
}

.status-tag {
  display: inline-flex;
  align-items: center;
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 16rpx;
  font-weight: 500;
}

.status-tag.active {
  background: linear-gradient(135deg, #C6F6D5 0%, #9AE6B4 100%);
  color: #276749;
}

.status-tag.inactive {
  background: #EDF2F7;
  color: #718096;
}

.card-actions {
  display: flex;
  gap: 16rpx;
}

.action-btn {
  font-size: 24rpx;
  padding: 10rpx 24rpx;
  border-radius: 12rpx;
  font-weight: 500;
  transition: all 0.3s ease;
}

.action-btn:active {
  transform: scale(0.95);
}

.action-btn.edit {
  background: linear-gradient(135deg, #BEE3F8 0%, #90CDF4 100%);
  color: #2B6CB0;
}

.action-btn.delete {
  background: linear-gradient(135deg, #FED7D7 0%, #FEB2B2 100%);
  color: #C53030;
}

.medication-card.inactive {
  opacity: 1;
  background: #F1F5F9;
  border: 2rpx dashed #CBD5E0;
}

.medication-card.inactive .med-name {
  color: #A0AEC0;
}

.action-btn.toggle {
  background: linear-gradient(135deg, #ED8936 0%, #DD6B20 100%);
  color: #fff;
  padding: 8rpx 20rpx;
  border-radius: 12rpx;
  font-size: 24rpx;
  font-weight: 500;
}

.action-btn.toggle.inactive {
  background: linear-gradient(135deg, #48BB78 0%, #38A169 100%);
}

/* 卡片内容 */
.card-body {
  margin-bottom: 24rpx;
}

.info-row {
  display: flex;
  margin-bottom: 16rpx;
  padding: 12rpx 0;
}

.info-label {
  font-size: 28rpx;
  color: #A0AEC0;
  width: 150rpx;
  font-weight: 500;
}

.info-value {
  font-size: 28rpx;
  color: #2D3748;
  flex: 1;
  font-weight: 500;
}

/* 卡片底部 */
.card-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 24rpx;
  border-top: 2rpx solid #F7FAFC;
}

.stock-info, .cycle-info {
  display: flex;
  align-items: center;
  padding: 12rpx 20rpx;
  background: #F7FAFC;
  border-radius: 12rpx;
}

.stock-label, .cycle-label {
  font-size: 26rpx;
  color: #A0AEC0;
  margin-right: 8rpx;
}

.stock-value {
  font-size: 26rpx;
  color: #48BB78;
  font-weight: 600;
}

.stock-value.warning {
  color: #F56565;
}

.cycle-value {
  font-size: 26rpx;
  color: #667EEA;
  font-weight: 600;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
  background: #fff;
  border-radius: 28rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.empty-icon {
  width: 120rpx;
  height: 120rpx;
  background: linear-gradient(135deg, #EDF2F7 0%, #E2E8F0 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 40rpx;
  font-size: 56rpx;
  color: #A0AEC0;
  font-weight: 300;
}

.empty-text {
  font-size: 32rpx;
  color: #4A5568;
  font-weight: 500;
  margin-bottom: 16rpx;
}

.empty-subtext {
  font-size: 26rpx;
  color: #A0AEC0;
}

/* 添加按钮 */
.add-btn {
  position: fixed;
  bottom: calc(240rpx + env(safe-area-inset-bottom));
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #667EEA 0%, #764BA2 100%);
  color: #fff;
  padding: 28rpx 72rpx;
  border-radius: 60rpx;
  box-shadow: 0 12rpx 40rpx rgba(102, 126, 234, 0.45);
  transition: all 0.3s ease;
  z-index: 100;
}

.add-btn:active {
  transform: translateX(-50%) scale(0.95);
}

.add-icon {
  font-size: 44rpx;
  margin-right: 12rpx;
  font-weight: 300;
}

.add-text {
  font-size: 32rpx;
  font-weight: 600;
}
