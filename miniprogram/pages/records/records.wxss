/* 服药记录页面样式 - 精致版 */
.container {
  padding: 24rpx;
  min-height: 100vh;
  background: linear-gradient(180deg, #EEF2FF 0%, #F8FAFC 50%, #F1F5F9 100%);
}

/* 日期选择器 */
.date-picker {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #fff;
  border-radius: 28rpx;
  padding: 32rpx;
  margin-bottom: 32rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04), 0 8rpx 32rpx rgba(0, 0, 0, 0.03);
  border: 1rpx solid rgba(226, 232, 240, 0.6);
}

.date-nav {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #F7FAFC 0%, #EDF2F7 100%);
  border-radius: 50%;
  transition: all 0.3s ease;
}

.date-nav:active {
  transform: scale(0.95);
  background: linear-gradient(135deg, #EBF4FF 0%, #C3DAFE 100%);
}

.nav-arrow {
  font-size: 28rpx;
  color: #4A5568;
  font-weight: 600;
}

.date-display {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.date-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 32rpx;
  background: linear-gradient(135deg, #F8FAFC 0%, #F1F5F9 100%);
  border-radius: 16rpx;
  border: 2rpx solid #E2E8F0;
}

.date-text {
  font-size: 38rpx;
  font-weight: 700;
  color: #2D3748;
}

.week-text {
  font-size: 26rpx;
  color: #A0AEC0;
  margin-top: 8rpx;
  font-weight: 500;
}

.picker-hint {
  font-size: 22rpx;
  color: #CBD5E0;
  margin-top: 8rpx;
}

/* 今日快捷按钮 */
.quick-today {
  display: flex;
  justify-content: center;
  margin-bottom: 24rpx;
}

.quick-today-text {
  font-size: 26rpx;
  color: #6366F1;
  font-weight: 500;
  padding: 12rpx 32rpx;
  background: linear-gradient(135deg, #EEF2FF 0%, #E0E7FF 100%);
  border-radius: 20rpx;
  border: 1rpx solid rgba(99, 102, 241, 0.2);
  transition: all 0.3s ease;
}

.quick-today:active .quick-today-text {
  transform: scale(0.98);
  background: linear-gradient(135deg, #C3DAFE 0%, #90CDF4 100%);
}

/* 记录列表 */
.record-list {
  margin-bottom: 32rpx;
}

.record-card {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 28rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04), 0 8rpx 32rpx rgba(0, 0, 0, 0.03);
  border: 1rpx solid rgba(226, 232, 240, 0.6);
  transition: all 0.3s ease;
}

.record-card:active {
  transform: scale(0.98);
}

.record-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
  font-size: 36rpx;
  font-weight: 700;
}

.record-icon.taken {
  background: linear-gradient(135deg, #C6F6D5 0%, #9AE6B4 100%);
  color: #276749;
  box-shadow: 0 4rpx 12rpx rgba(72, 187, 120, 0.3);
}

.record-icon.missed {
  background: linear-gradient(135deg, #FED7D7 0%, #FEB2B2 100%);
  color: #C53030;
  box-shadow: 0 4rpx 12rpx rgba(245, 101, 101, 0.3);
}

.record-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.record-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #2D3748;
  margin-bottom: 8rpx;
}

.record-dosage {
  font-size: 26rpx;
  color: #718096;
}

.record-time {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
}

.time-text {
  font-size: 30rpx;
  color: #2D3748;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.status-text {
  font-size: 24rpx;
  font-weight: 600;
  padding: 6rpx 16rpx;
  border-radius: 12rpx;
}

.status-text.taken {
  background: linear-gradient(135deg, #C6F6D5 0%, #9AE6B4 100%);
  color: #276749;
}

.status-text.missed {
  background: linear-gradient(135deg, #FED7D7 0%, #FEB2B2 100%);
  color: #C53030;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
  background: #fff;
  border-radius: 32rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04), 0 8rpx 32rpx rgba(0, 0, 0, 0.03);
  border: 1rpx solid rgba(226, 232, 240, 0.6);
  position: relative;
  overflow: hidden;
}

.empty-state::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 6rpx;
  background: linear-gradient(90deg, #6366F1, #A78BFA, #6366F1);
}

.empty-text {
  font-size: 34rpx;
  color: #334155;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.empty-subtext {
  font-size: 26rpx;
  color: #94A3B8;
}

/* 统计摘要 */
.summary {
  display: flex;
  justify-content: space-around;
  background: #fff;
  border-radius: 28rpx;
  padding: 40rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04), 0 8rpx 32rpx rgba(0, 0, 0, 0.03);
  border: 1rpx solid rgba(226, 232, 240, 0.6);
}

.summary-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 40rpx;
  background: #F7FAFC;
  border-radius: 20rpx;
}

.summary-value {
  font-size: 52rpx;
  font-weight: 700;
  margin-bottom: 12rpx;
}

.summary-value.taken {
  color: #48BB78;
}

.summary-value.missed {
  color: #F56565;
}

.summary-value.total {
  color: #6366F1;
}

.summary-label {
  font-size: 26rpx;
  color: #718096;
  font-weight: 500;
}
