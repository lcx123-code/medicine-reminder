/* 隐私协议页面样式 */
.container {
  padding: 24rpx;
  min-height: 100vh;
  background: linear-gradient(180deg, #EEF2FF 0%, #F8FAFC 50%, #F1F5F9 100%);
}

.policy-card {
  background: #fff;
  border-radius: 32rpx;
  padding: 40rpx 36rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.03), 0 6rpx 24rpx rgba(0, 0, 0, 0.04);
  border: 1rpx solid rgba(226, 232, 240, 0.6);
  position: relative;
  overflow: hidden;
}

.policy-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 6rpx;
  background: linear-gradient(90deg, #6366F1, #A78BFA, #6366F1);
}

.policy-title {
  display: block;
  font-size: 40rpx;
  font-weight: 800;
  color: #1E293B;
  text-align: center;
  margin-bottom: 20rpx;
}

.policy-date {
  display: block;
  font-size: 24rpx;
  color: #94A3B8;
  text-align: center;
  margin-bottom: 8rpx;
}

.policy-section {
  margin-top: 40rpx;
}

.section-title {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: #334155;
  margin-bottom: 16rpx;
}

.section-text {
  display: block;
  font-size: 28rpx;
  color: #475569;
  line-height: 1.8;
  margin-bottom: 12rpx;
}
