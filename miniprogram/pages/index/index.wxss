/* 首页样式 - 精致医疗风 */
.container {
  padding: 24rpx;
  min-height: 100vh;
  background: linear-gradient(180deg, #EEF2FF 0%, #F8FAFC 50%, #F1F5F9 100%);
}

/* 通知授权提示条 */
.notify-banner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 28rpx;
  margin-bottom: 24rpx;
  background: linear-gradient(135deg, #EEF2FF 0%, #E0E7FF 100%);
  border-radius: 24rpx;
  border: 1rpx solid rgba(99, 102, 241, 0.2);
}

.notify-banner-text {
  display: flex;
  align-items: center;
  flex: 1;
}

.notify-icon {
  width: 40rpx;
  height: 40rpx;
  line-height: 40rpx;
  text-align: center;
  background: linear-gradient(135deg, #6366F1, #818CF8);
  color: #fff;
  font-size: 24rpx;
  font-weight: 700;
  border-radius: 50%;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.notify-msg {
  font-size: 26rpx;
  color: #4338CA;
  font-weight: 500;
  flex: 1;
}

.notify-btn {
  font-size: 24rpx;
  color: #fff;
  background: linear-gradient(135deg, #6366F1, #818CF8);
  padding: 10rpx 24rpx;
  border-radius: 20rpx;
  font-weight: 600;
  margin-left: 16rpx;
  flex-shrink: 0;
}

.notify-close {
  font-size: 36rpx;
  color: #94A3B8;
  padding: 0 8rpx;
  margin-left: 12rpx;
  flex-shrink: 0;
}

/* 骨架屏样式 */
.skeleton {
  padding: 24rpx;
}

.skeleton-header {
  padding: 40rpx 36rpx;
  background: linear-gradient(135deg, #E2E8F0 0%, #CBD5E0 100%);
  border-radius: 32rpx;
  margin-bottom: 32rpx;
  animation: skeleton-pulse 1.5s ease-in-out infinite;
}

.skeleton-card {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.skeleton-circle {
  width: 80rpx;
  height: 80rpx;
  background: linear-gradient(135deg, #E2E8F0 0%, #CBD5E0 100%);
  border-radius: 50%;
  margin-right: 24rpx;
  animation: skeleton-pulse 1.5s ease-in-out infinite;
}

.skeleton-content {
  flex: 1;
}

.skeleton-line {
  height: 28rpx;
  background: linear-gradient(135deg, #E2E8F0 0%, #CBD5E0 100%);
  border-radius: 8rpx;
  margin-bottom: 16rpx;
  animation: skeleton-pulse 1.5s ease-in-out infinite;
}

.skeleton-title {
  width: 200rpx;
  height: 48rpx;
}

.skeleton-subtitle {
  width: 120rpx;
  height: 24rpx;
}

.skeleton-name {
  width: 60%;
}

.skeleton-desc {
  width: 40%;
}

@keyframes skeleton-pulse {
  0%, 100% {
    opacity: 1;
  }
  50% {
    opacity: 0.5;
  }
}

/* 日期头部 */
.date-header {
  display: flex;
  align-items: center;
  padding: 40rpx 36rpx;
  background: linear-gradient(135deg, #6366F1 0%, #8B5CF6 50%, #A78BFA 100%);
  border-radius: 32rpx;
  margin-bottom: 32rpx;
  box-shadow: 0 16rpx 48rpx rgba(99, 102, 241, 0.35);
  position: relative;
  overflow: hidden;
}

.date-header::before {
  content: '';
  position: absolute;
  top: -60rpx;
  right: -40rpx;
  width: 200rpx;
  height: 200rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 50%;
}

.date-header::after {
  content: '';
  position: absolute;
  bottom: -50rpx;
  left: 30%;
  width: 160rpx;
  height: 160rpx;
  background: rgba(255, 255, 255, 0.06);
  border-radius: 50%;
}

.date-info {
  flex: 1;
  z-index: 1;
}

.date-text {
  font-size: 56rpx;
  font-weight: 800;
  color: #fff;
  display: block;
  margin-bottom: 8rpx;
  letter-spacing: 1rpx;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.week-text {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
  font-weight: 500;
  letter-spacing: 0.5rpx;
}

.date-icon {
  width: 88rpx;
  height: 88rpx;
  background: rgba(255, 255, 255, 0.2);
  backdrop-filter: blur(10px);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
  z-index: 1;
  border: 2rpx solid rgba(255, 255, 255, 0.3);
}

/* 提醒列表 */
.reminder-list {
  margin-bottom: 32rpx;
}

.section-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #1E293B;
  margin-bottom: 24rpx;
  padding-left: 12rpx;
  display: flex;
  align-items: center;
}

.section-title::before {
  content: '';
  width: 8rpx;
  height: 32rpx;
  background: linear-gradient(180deg, #6366F1, #A78BFA);
  border-radius: 4rpx;
  margin-right: 16rpx;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
  background: #fff;
  border-radius: 32rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04), 0 8rpx 32rpx rgba(0, 0, 0, 0.03);
  border: 1rpx solid rgba(226, 232, 240, 0.6);
  position: relative;
  
}

.empty-state::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 6rpx;
  background: linear-gradient(90deg, #6366F1, #A78BFA, #6366F1);
}

.empty-icon {
  width: 240rpx;
  height: 240rpx;
  margin-bottom: 36rpx;
  opacity: 0.8;
}

.empty-text {
  font-size: 34rpx;
  color: #334155;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.empty-subtext {
  font-size: 26rpx;
  color: #94A3B8;
}

/* 库存预警 */
.stock-warning {
  background: linear-gradient(135deg, #FFFBEB 0%, #FEF3C7 100%);
  border-radius: 28rpx;
  padding: 32rpx;
  margin-top: 32rpx;
  border: 1rpx solid #FDE68A;
  position: relative;
  
}

.warning-title {
  display: flex;
  align-items: center;
  font-size: 32rpx;
  font-weight: 700;
  color: #92400E;
  margin-bottom: 24rpx;
}

.warning-icon {
  width: 44rpx;
  height: 44rpx;
  margin-right: 14rpx;
  font-size: 40rpx;
}

.warning-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.warning-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 28rpx;
  background: #fff;
  border-radius: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
  border: 1rpx solid rgba(253, 230, 138, 0.5);
}

.warning-name {
  font-size: 28rpx;
  color: #1E293B;
  font-weight: 500;
}

.warning-stock {
  font-size: 26rpx;
  color: #D97706;
  font-weight: 700;
  background: rgba(217, 119, 6, 0.08);
  padding: 6rpx 16rpx;
  border-radius: 12rpx;
}
