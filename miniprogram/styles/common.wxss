/**
 * 公共样式文件
 * 提供可复用的样式类，减少重复代码
 */

/* ==================== 布局样式 ==================== */

/* 卡片容器（app.wxss 已有同名类，此处仅补充） */
.card {
  background: #fff;
  border-radius: 28rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04), 0 8rpx 32rpx rgba(0, 0, 0, 0.03);
  border: 1rpx solid rgba(226, 232, 240, 0.6);
}

/* ==================== 骨架屏样式 ==================== */

.skeleton-line {
  height: 28rpx;
  background: linear-gradient(135deg, #E2E8F0 0%, #CBD5E0 100%);
  border-radius: 8rpx;
  animation: skeleton-pulse 1.5s ease-in-out infinite;
}

@keyframes skeleton-pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.5; }
}

/* ==================== 空状态样式 ==================== */

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
  background: #fff;
  border-radius: 28rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.empty-icon-wrapper {
  width: 160rpx;
  height: 160rpx;
  background: linear-gradient(135deg, #EDF2F7 0%, #E2E8F0 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 40rpx;
}

.empty-icon-text {
  font-size: 64rpx;
  color: #A0AEC0;
  font-weight: 300;
}

.empty-text {
  font-size: 32rpx;
  color: #4A5568;
  font-weight: 500;
  margin-bottom: 16rpx;
}

.empty-subtext {
  font-size: 26rpx;
  color: #A0AEC0;
}

/* ==================== 按钮样式 ==================== */

/* 主要按钮 */
.btn-primary {
  background: linear-gradient(135deg, #6366F1 0%, #8B5CF6 50%, #A78BFA 100%);
  color: #fff;
  border-radius: 20rpx;
  font-size: 30rpx;
  font-weight: 600;
  box-shadow: 0 8rpx 24rpx rgba(99, 102, 241, 0.35);
  transition: all 0.3s ease;
}

.btn-primary:active {
  transform: scale(0.97);
  box-shadow: 0 4rpx 12rpx rgba(99, 102, 241, 0.3);
}

/* 次要按钮 */
.btn-secondary {
  background: linear-gradient(135deg, #F8FAFC 0%, #F1F5F9 100%);
  color: #475569;
  border: 1rpx solid #E2E8F0;
  border-radius: 20rpx;
  padding: 26rpx 52rpx;
  font-size: 30rpx;
  font-weight: 500;
  text-align: center;
  transition: all 0.3s ease;
}

.btn-secondary:active {
  background: #F1F5F9;
  transform: scale(0.97);
}

/* 危险按钮 */
.btn-danger {
  background: linear-gradient(135deg, #F87171 0%, #EF4444 100%);
  color: #fff;
  border: none;
  border-radius: 20rpx;
  padding: 26rpx 52rpx;
  font-size: 30rpx;
  font-weight: 600;
  text-align: center;
  box-shadow: 0 8rpx 24rpx rgba(239, 68, 68, 0.35);
}

/* ==================== 标签样式 ==================== */
.tag {
  display: inline-flex;
  align-items: center;
  padding: 8rpx 22rpx;
  border-radius: 24rpx;
  font-size: 24rpx;
  font-weight: 500;
}

.tag-primary {
  background: rgba(99, 102, 241, 0.1);
  color: #6366F1;
}

.tag-success {
  background: rgba(16, 185, 129, 0.1);
  color: #10B981;
}

.tag-warning {
  background: rgba(245, 158, 11, 0.1);
  color: #F59E0B;
}

.tag-danger {
  background: rgba(239, 68, 68, 0.1);
  color: #EF4444;
}

/* ==================== 警告提示样式 ==================== */

.warning-box {
  background: linear-gradient(135deg, #FFFBEB 0%, #FEF3C7 100%);
  border-radius: 28rpx;
  padding: 32rpx;
  margin-top: 32rpx;
  border: 1rpx solid #FDE68A;
  position: relative;
  overflow: hidden;
}

.warning-box::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  width: 8rpx;
  height: 100%;
  background: linear-gradient(180deg, #F59E0B, #D97706);
  border-radius: 4rpx;
}

.warning-title {
  display: flex;
  align-items: center;
  font-size: 32rpx;
  font-weight: 700;
  color: #92400E;
  margin-bottom: 16rpx;
}

.warning-icon {
  width: 40rpx;
  height: 40rpx;
  background: #F59E0B;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 12rpx;
  color: #fff;
  font-size: 24rpx;
  font-weight: 700;
}

/* ==================== 工具类 ==================== */

/* 文字截断 */
.text-ellipsis {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 弹性布局 */
.flex-center {
  display: flex;
  align-items: center;
  justify-content: center;
}

.flex-between {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

/* 间距 */
.mt-16 { margin-top: 16rpx; }
.mt-24 { margin-top: 24rpx; }
.mt-32 { margin-top: 32rpx; }
.mb-16 { margin-bottom: 16rpx; }
.mb-24 { margin-bottom: 24rpx; }
.mb-32 { margin-bottom: 32rpx; }
