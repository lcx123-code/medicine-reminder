/* 统计分析页面样式 - 精致医疗风 */
.container {
  padding: 24rpx;
  min-height: 100vh;
  background: linear-gradient(180deg, #EEF2FF 0%, #F8FAFC 50%, #F1F5F9 100%);
}

/* 周期选择 */
.period-tabs {
  display: flex;
  background: #fff;
  border-radius: 24rpx;
  padding: 10rpx;
  margin-bottom: 32rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.03), 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
  border: 1rpx solid rgba(226, 232, 240, 0.6);
}

.period-tab {
  flex: 1;
  height: 84rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 18rpx;
  font-size: 30rpx;
  color: #64748B;
  font-weight: 500;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

.period-tab.active {
  background: linear-gradient(135deg, #6366F1 0%, #8B5CF6 50%, #A78BFA 100%);
  color: #fff;
  font-weight: 700;
  box-shadow: 0 6rpx 24rpx rgba(99, 102, 241, 0.35);
  position: relative;
  overflow: hidden;
}

.period-tab.active::after {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 50%;
  background: linear-gradient(180deg, rgba(255,255,255,0.15) 0%, rgba(255,255,255,0) 100%);
  border-radius: 18rpx 18rpx 0 0;
}

/* 统计卡片 */
.stats-card {
  background: #fff;
  border-radius: 32rpx;
  padding: 40rpx;
  margin-bottom: 28rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.03), 0 6rpx 24rpx rgba(0, 0, 0, 0.04);
  border: 1rpx solid rgba(226, 232, 240, 0.6);
  position: relative;
  overflow: hidden;
}

.stats-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 6rpx;
  background: linear-gradient(90deg, #6366F1, #A78BFA, #6366F1);
}

.card-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #1E293B;
  margin-bottom: 36rpx;
  padding-left: 20rpx;
  border-left: 8rpx solid #6366F1;
  position: relative;
  z-index: 1;
}

/* 依从性图表 */
.adherence-chart {
  position: relative;
  width: 340rpx;
  height: 340rpx;
  margin: 0 auto 44rpx;
  z-index: 1;
}

.chart-center {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  display: flex;
  flex-direction: column;
  align-items: center;
  z-index: 10;
}

.chart-value {
  font-size: 72rpx;
  font-weight: 800;
  color: #6366F1;
}

.chart-label {
  font-size: 28rpx;
  color: #94A3B8;
  margin-top: 8rpx;
  font-weight: 500;
}

.chart-ring {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  border: 28rpx solid #E2E8F0;
  box-sizing: border-box;
  position: relative;
  overflow: hidden;
}

.ring-fill {
  position: absolute;
  top: -28rpx;
  left: -28rpx;
  right: -28rpx;
  bottom: -28rpx;
  border-radius: 50%;
  border: 28rpx solid transparent;
  border-top-color: #10B981;
  border-right-color: #10B981;
  transform-origin: center;
}

.chart-status {
  position: absolute;
  bottom: -10rpx;
  left: 50%;
  transform: translateX(-50%);
  padding: 8rpx 24rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  font-weight: 600;
  z-index: 10;
}

.chart-status.good {
  background: linear-gradient(135deg, #D1FAE5 0%, #A7F3D0 100%);
  color: #065F46;
}

.chart-status.normal {
  background: linear-gradient(135deg, #FEF9C3 0%, #FDE68A 100%);
  color: #92400E;
}

.chart-status.bad {
  background: linear-gradient(135deg, #FEE2E2 0%, #FECACA 100%);
  color: #991B1B;
}

/* 统计摘要 */
.stats-summary {
  display: flex;
  justify-content: space-around;
  padding-top: 36rpx;
  border-top: 1rpx solid #F1F5F9;
  position: relative;
  z-index: 1;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 36rpx;
  background: linear-gradient(135deg, #F8FAFC 0%, #F1F5F9 100%);
  border-radius: 20rpx;
  border: 1rpx solid #E2E8F0;
}

.stat-value {
  font-size: 52rpx;
  font-weight: 800;
  margin-bottom: 10rpx;
}

.stat-value.completed { color: #10B981; }
.stat-value.missed { color: #EF4444; }
.stat-value.pending { color: #F59E0B; }

.stat-label {
  font-size: 26rpx;
  color: #64748B;
  font-weight: 500;
}

/* 每日统计图表 */
.daily-chart {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  height: 260rpx;
  padding: 36rpx 24rpx 0;
  background: linear-gradient(135deg, #F8FAFC 0%, #F1F5F9 100%);
  border-radius: 24rpx;
  border: 1rpx solid #E2E8F0;
  position: relative;
  z-index: 1;
}

.chart-bar {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.bar-container {
  width: 52rpx;
  height: 180rpx;
  background: #E2E8F0;
  border-radius: 14rpx;
  overflow: hidden;
  position: relative;
}

.bar-fill {
  position: absolute;
  bottom: 0;
  width: 100%;
  background: linear-gradient(180deg, #6366F1 0%, #8B5CF6 50%, #A78BFA 100%);
  border-radius: 14rpx;
  transition: height 0.6s cubic-bezier(0.4, 0, 0.2, 1);
  box-shadow: 0 -4rpx 16rpx rgba(99, 102, 241, 0.25);
}

.bar-label {
  font-size: 22rpx;
  color: #64748B;
  margin-top: 14rpx;
  font-weight: 500;
}

/* 药品统计 */
.medication-stats {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  position: relative;
  z-index: 1;
}

.med-stat-item {
  padding: 32rpx;
  background: linear-gradient(135deg, #F8FAFC 0%, #F1F5F9 100%);
  border-radius: 24rpx;
  border: 1rpx solid #E2E8F0;
}

.med-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.med-name {
  font-size: 32rpx;
  color: #1E293B;
  font-weight: 700;
}

.med-rate {
  font-size: 38rpx;
  font-weight: 800;
  padding: 10rpx 24rpx;
  border-radius: 16rpx;
}

.med-rate.good {
  background: linear-gradient(135deg, #D1FAE5 0%, #A7F3D0 100%);
  color: #065F46;
}

.med-rate.normal {
  background: linear-gradient(135deg, #FEF9C3 0%, #FDE68A 100%);
  color: #92400E;
}

.med-rate.bad {
  background: linear-gradient(135deg, #FEE2E2 0%, #FECACA 100%);
  color: #991B1B;
}

.med-progress {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.progress-bar {
  flex: 1;
  height: 20rpx;
  background: #E2E8F0;
  border-radius: 10rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #6366F1 0%, #8B5CF6 50%, #A78BFA 100%);
  border-radius: 10rpx;
  transition: width 0.6s cubic-bezier(0.4, 0, 0.2, 1);
  box-shadow: 0 2rpx 8rpx rgba(99, 102, 241, 0.25);
}

.progress-text {
  font-size: 26rpx;
  color: #64748B;
  min-width: 100rpx;
  text-align: right;
  font-weight: 600;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
  background: #fff;
  border-radius: 32rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04), 0 8rpx 32rpx rgba(0, 0, 0, 0.03);
  border: 1rpx solid rgba(226, 232, 240, 0.6);
  position: relative;
  overflow: hidden;
}

.empty-state::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 6rpx;
  background: linear-gradient(90deg, #6366F1, #A78BFA, #6366F1);
}

.empty-text {
  font-size: 34rpx;
  color: #334155;
  font-weight: 600;
  margin-bottom: 16rpx;
}

.empty-subtext {
  font-size: 26rpx;
  color: #94A3B8;
}
