/**
 * 公共样式文件
 * 提供可复用的样式类，减少重复代码
 */

/* ==================== 布局样式 ==================== */

/* 页面容器 */
.page-container {
  padding: 24rpx;
  min-height: 100vh;
  background: linear-gradient(180deg, #EEF2FF 0%, #F8FAFC 50%, #F1F5F9 100%);
}

/* 卡片容器 */
.card {
  background: #fff;
  border-radius: 28rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 6rpx 24rpx rgba(0, 0, 0, 0.06);
  border: 1rpx solid rgba(255, 255, 255, 0.8);
}

/* ==================== 骨架屏样式 ==================== */

.skeleton-line {
  height: 28rpx;
  background: linear-gradient(135deg, #E2E8F0 0%, #CBD5E0 100%);
  border-radius: 8rpx;
  animation: skeleton-pulse 1.5s ease-in-out infinite;
}

@keyframes skeleton-pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.5; }
}

/* ==================== 空状态样式 ==================== */

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
  background: #fff;
  border-radius: 28rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.empty-icon-wrapper {
  width: 160rpx;
  height: 160rpx;
  background: linear-gradient(135deg, #EDF2F7 0%, #E2E8F0 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 40rpx;
}

.empty-icon-text {
  font-size: 64rpx;
  color: #A0AEC0;
  font-weight: 300;
}

.empty-text {
  font-size: 32rpx;
  color: #4A5568;
  font-weight: 500;
  margin-bottom: 16rpx;
}

.empty-subtext {
  font-size: 26rpx;
  color: #A0AEC0;
}

/* ==================== 按钮样式 ==================== */

/* 主要按钮 */
.btn-primary {
  background: linear-gradient(135deg, #667EEA 0%, #764BA2 100%);
  color: #fff;
  border-radius: 52rpx;
  font-size: 34rpx;
  font-weight: 600;
  box-shadow: 0 12rpx 40rpx rgba(102, 126, 234, 0.45);
  transition: all 0.3s ease;
}

.btn-primary:active {
  transform: scale(0.98);
  box-shadow: 0 6rpx 20rpx rgba(102, 126, 234, 0.35);
}

/* 次要按钮 */
.btn-secondary {
  background: linear-gradient(135deg, #F7FAFC 0%, #EDF2F7 100%);
  color: #4A5568;
  border-radius: 16rpx;
  font-size: 28rpx;
  font-weight: 500;
  border: 2rpx solid #E2E8F0;
  transition: all 0.3s ease;
}

.btn-secondary:active {
  transform: scale(0.98);
  background: linear-gradient(135deg, #EDF2F7 0%, #E2E8F0 100%);
}

/* 危险按钮 */
.btn-danger {
  background: linear-gradient(135deg, #FED7D7 0%, #FEB2B2 100%);
  color: #C53030;
  border-radius: 12rpx;
  font-size: 24rpx;
  font-weight: 500;
  transition: all 0.3s ease;
}

.btn-danger:active {
  transform: scale(0.95);
  background: linear-gradient(135deg, #FEB2B2 0%, #FC8181 100%);
}

/* ==================== 表单样式 ==================== */

.form-input {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #F7FAFC 0%, #EDF2F7 100%);
  border-radius: 16rpx;
  padding: 0 28rpx;
  font-size: 30rpx;
  box-sizing: border-box;
  border: 2rpx solid transparent;
  transition: all 0.3s ease;
}

.form-input:focus {
  border-color: #667EEA;
  background: #fff;
  box-shadow: 0 0 0 4rpx rgba(102, 126, 234, 0.1);
}

.form-label {
  display: block;
  font-size: 28rpx;
  color: #4A5568;
  font-weight: 600;
  margin-bottom: 16rpx;
}

.form-picker {
  display: flex;
  justify-content: space-between;
  align-items: center;
  height: 88rpx;
  background: linear-gradient(135deg, #F7FAFC 0%, #EDF2F7 100%);
  border-radius: 16rpx;
  padding: 0 28rpx;
  font-size: 30rpx;
  border: 2rpx solid transparent;
  transition: all 0.3s ease;
}

.form-picker:active {
  border-color: #667EEA;
}

.picker-arrow {
  font-size: 24rpx;
  color: #A0AEC0;
}

/* ==================== 状态标签样式 ==================== */

/* 启用状态 */
.tag-active {
  display: inline-flex;
  align-items: center;
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 16rpx;
  font-weight: 500;
  background: linear-gradient(135deg, #C6F6D5 0%, #9AE6B4 100%);
  color: #276749;
}

/* 停用状态 */
.tag-inactive {
  display: inline-flex;
  align-items: center;
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 16rpx;
  font-weight: 500;
  background: #EDF2F7;
  color: #718096;
}

/* 成功状态 */
.tag-success {
  background: linear-gradient(135deg, #C6F6D5 0%, #9AE6B4 100%);
  color: #276749;
}

/* 警告状态 */
.tag-warning {
  background: linear-gradient(135deg, #FEF9C3 0%, #FDE68A 100%);
  color: #92400E;
}

/* 危险状态 */
.tag-danger {
  background: linear-gradient(135deg, #FEE2E2 0%, #FECACA 100%);
  color: #991B1B;
}

/* ==================== 警告提示样式 ==================== */

.warning-box {
  background: linear-gradient(135deg, #FFFBEB 0%, #FEF3C7 100%);
  border-radius: 28rpx;
  padding: 32rpx;
  margin-top: 32rpx;
  border: 1rpx solid #FDE68A;
  position: relative;
  overflow: hidden;
}

.warning-box::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  width: 8rpx;
  height: 100%;
  background: linear-gradient(180deg, #F59E0B, #D97706);
  border-radius: 4rpx;
}

.warning-title {
  display: flex;
  align-items: center;
  font-size: 32rpx;
  font-weight: 700;
  color: #92400E;
  margin-bottom: 16rpx;
}

.warning-icon {
  width: 40rpx;
  height: 40rpx;
  background: #F59E0B;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 12rpx;
  color: #fff;
  font-size: 24rpx;
  font-weight: 700;
}

/* ==================== 工具类 ==================== */

/* 文字截断 */
.text-ellipsis {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 弹性布局 */
.flex-center {
  display: flex;
  align-items: center;
  justify-content: center;
}

.flex-between {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

/* 间距 */
.mt-16 { margin-top: 16rpx; }
.mt-24 { margin-top: 24rpx; }
.mt-32 { margin-top: 32rpx; }
.mb-16 { margin-bottom: 16rpx; }
.mb-24 { margin-bottom: 24rpx; }
.mb-32 { margin-bottom: 32rpx; }
