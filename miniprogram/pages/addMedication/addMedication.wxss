/* 添加药品页面样式 - 精致版 */
.container {
  padding: 24rpx;
  min-height: 100vh;
  background: linear-gradient(180deg, #E8F4FD 0%, #F5F7FA 100%);
  padding-bottom: 150rpx;
}

.form {
  background: #fff;
  border-radius: 28rpx;
  padding: 32rpx;
  box-shadow: 0 6rpx 24rpx rgba(0, 0, 0, 0.06);
}

.form-item {
  padding: 28rpx 0;
  border-bottom: 2rpx solid #F7FAFC;
}

.form-item:last-child {
  border-bottom: none;
}

.form-label {
  display: block;
  font-size: 28rpx;
  color: #4A5568;
  font-weight: 600;
  margin-bottom: 16rpx;
}

.form-input {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #F7FAFC 0%, #EDF2F7 100%);
  border-radius: 16rpx;
  padding: 0 28rpx;
  font-size: 30rpx;
  box-sizing: border-box;
  border: 2rpx solid transparent;
  transition: all 0.3s ease;
}

.form-input:focus {
  border-color: #667EEA;
  background: #fff;
  box-shadow: 0 0 0 4rpx rgba(102, 126, 234, 0.1);
}

.form-picker {
  display: flex;
  justify-content: space-between;
  align-items: center;
  height: 88rpx;
  background: linear-gradient(135deg, #F7FAFC 0%, #EDF2F7 100%);
  border-radius: 16rpx;
  padding: 0 28rpx;
  font-size: 30rpx;
  border: 2rpx solid transparent;
  transition: all 0.3s ease;
}

.form-picker:active {
  border-color: #667EEA;
}

.picker-arrow {
  font-size: 24rpx;
  color: #A0AEC0;
}

/* 时间列表 */
.time-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.time-item {
  display: flex;
  align-items: center;
  background: linear-gradient(135deg, #EBF4FF 0%, #C3DAFE 100%);
  border-radius: 12rpx;
  padding: 14rpx 24rpx;
  border: 1rpx solid #90CDF4;
}

.time-text {
  font-size: 28rpx;
  color: #2B6CB0;
  font-weight: 600;
  margin-right: 12rpx;
}

.time-delete {
  font-size: 36rpx;
  color: #90CDF4;
  padding: 0 8rpx;
  transition: color 0.3s ease;
}

.time-delete:active {
  color: #F56565;
}

.time-add {
  background: linear-gradient(135deg, #F7FAFC 0%, #EDF2F7 100%);
  border-radius: 12rpx;
  padding: 14rpx 24rpx;
  font-size: 28rpx;
  color: #667EEA;
  font-weight: 500;
  border: 2rpx dashed #CBD5E0;
  transition: all 0.3s ease;
}

.time-add:active {
  background: #EBF4FF;
  border-color: #667EEA;
}

/* 库存输入组 */
.stock-input-group {
  display: flex;
  gap: 16rpx;
}

.stock-input {
  flex: 1;
}

.unit-picker {
  width: 180rpx;
}

/* 用药周期 */
.cycle-group {
  display: flex;
  gap: 16rpx;
}

.cycle-picker {
  flex: 1;
}

/* 保存按钮 */
.save-btn {
  position: fixed;
  bottom: 60rpx;
  left: 48rpx;
  right: 48rpx;
  height: 104rpx;
  background: linear-gradient(135deg, #667EEA 0%, #764BA2 100%);
  border-radius: 52rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 34rpx;
  font-weight: 600;
  color: #fff;
  box-shadow: 0 12rpx 40rpx rgba(102, 126, 234, 0.45);
  transition: all 0.3s ease;
  z-index: 100;
}

.save-btn:active {
  transform: scale(0.98);
  box-shadow: 0 6rpx 20rpx rgba(102, 126, 234, 0.35);
}

/* 文本域样式 */
.form-textarea {
  width: 100%;
  min-height: 160rpx;
  background: linear-gradient(135deg, #F7FAFC 0%, #EDF2F7 100%);
  border-radius: 16rpx;
  padding: 24rpx 28rpx;
  font-size: 30rpx;
  box-sizing: border-box;
  border: 2rpx solid transparent;
  transition: all 0.3s ease;
  line-height: 1.6;
}

.form-textarea:focus {
  border-color: #667EEA;
  background: #fff;
  box-shadow: 0 0 0 4rpx rgba(102, 126, 234, 0.1);
}

.textarea-count {
  display: block;
  text-align: right;
  font-size: 24rpx;
  color: #A0AEC0;
  margin-top: 12rpx;
}

/* 时间选择器 */
.time-picker-row {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 16rpx;
  gap: 12rpx;
}

.time-picker-btn {
  background: linear-gradient(135deg, #EDF2F7 0%, #E2E8F0 100%);
  border-radius: 16rpx;
  padding: 16rpx 32rpx;
  font-size: 30rpx;
  color: #4A5568;
  font-weight: 500;
  min-width: 100rpx;
  text-align: center;
}

.time-sep {
  font-size: 36rpx;
  color: #A0AEC0;
  font-weight: 700;
}

.time-add-btn {
  background: linear-gradient(135deg, #667EEA 0%, #764BA2 100%);
  border-radius: 16rpx;
  padding: 16rpx 28rpx;
  font-size: 28rpx;
  color: #fff;
  font-weight: 600;
}

.time-add-btn:active {
  transform: scale(0.95);
}
