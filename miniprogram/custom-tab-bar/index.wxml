<view class="tab-bar" style="transform: translateY({{visible ? 0 : '100%'}});">
  <view class="tab-bar-inner">
    <!-- 浮动胶囊指示器 -->
    <view class="pill" style="transform: translateX({{selected * 100}}%); background: {{list[selected].gradient}};"></view>
    <!-- Tab 项 -->
    <view
      class="tab-item {{selected === index ? 'active' : ''}}"
      wx:for="{{list}}"
      wx:key="index"
      data-path="{{item.pagePath}}"
      data-index="{{index}}"
      bindtap="switchTab"
    >
      <text class="tab-text {{selected === index ? 'active' : ''}}" style="color: {{selected === index ? '#fff' : item.inactiveColor}};">{{item.text}}</text>
    </view>
  </view>
</view>
