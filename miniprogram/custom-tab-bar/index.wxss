.tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: calc(96rpx + env(safe-area-inset-bottom));
  padding-bottom: env(safe-area-inset-bottom);
  display: flex;
  align-items: flex-start;
  justify-content: center;
  z-index: 999;
  background: transparent;
  transition: transform 0.3s ease;
}

.tab-bar-inner {
  position: relative;
  display: flex;
  align-items: center;
  width: 88%;
  height: 96rpx;
  padding: 0 16rpx;
  box-sizing: border-box;
  background: rgba(255, 255, 255, 0.72);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border-radius: 28rpx;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.08), 0 1rpx 4rpx rgba(0, 0, 0, 0.04);
  border: 1rpx solid rgba(255, 255, 255, 0.4);
}

.pill {
  position: absolute;
  top: 6rpx;
  left: 16rpx;
  width: calc((100% - 32rpx) / 4);
  height: 84rpx;
  border-radius: 22rpx;
  transition: transform 0.35s cubic-bezier(0.34, 1.56, 0.64, 1);
  z-index: 0;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.12);
}

.tab-item {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 1;
  height: 100%;
  z-index: 1;
}

.tab-text {
  font-size: 24rpx;
  font-weight: 500;
  transition: color 0.3s ease, font-weight 0.3s ease;
}

.tab-text.active {
  font-weight: 700;
}
